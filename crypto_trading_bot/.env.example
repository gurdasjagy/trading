# ============ GATE.IO API KEYS (SOLE EXCHANGE) ============
# Gate.io is used for ALL trading modes:
#   live/paper:  GATEIO_API_KEY / GATEIO_SECRET_KEY (crypto futures)
#   testnet:     GATEIO_TESTNET_API_KEY / GATEIO_TESTNET_SECRET_KEY
#   forex_live:  GATEIO_TRADFI_LOGIN / PASSWORD / SERVER (MT5)
#   forex_demo:  GATEIO_TRADFI_DEMO_LOGIN / PASSWORD / SERVER (MT5)
GATEIO_API_KEY=your_gateio_api_key
GATEIO_SECRET_KEY=your_gateio_secret_key

# ── Gate.io TradFi credentials (required for forex_live and forex_demo modes) ──────
# NEW: Gate.io TradFi uses MetaTrader 5 (MT5) infrastructure for Forex and Precious Metals
# You need MT5 account credentials from Gate.io TradFi platform
# Get your Gate.io TradFi MT5 account at: https://www.gate.io/tradfi
# MT5 account login number (not API key!)
GATEIO_TRADFI_LOGIN=your_gateio_tradfi_mt5_login
# MT5 account password
GATEIO_TRADFI_PASSWORD=your_gateio_tradfi_mt5_password
# MT5 server address (e.g., "GateIO-TradFi" for live, "GateIO-TradFi-Demo" for demo)
GATEIO_TRADFI_SERVER=GateIO-TradFi
# Account type: "Standard" or "Pro"
GATEIO_TRADFI_ACCOUNT_TYPE=Standard

# For forex_demo mode (Gate.io TradFi demo account)
# GATEIO_TRADFI_DEMO_LOGIN=your_gateio_tradfi_demo_login
# GATEIO_TRADFI_DEMO_PASSWORD=your_gateio_tradfi_demo_password
# GATEIO_TRADFI_DEMO_SERVER=GateIO-TradFi-Demo
# GATEIO_TRADFI_DEMO_ACCOUNT_TYPE=Standard

# ── Gate.io Testnet credentials (used when TRADING_MODE=testnet) ──
GATEIO_TESTNET_API_KEY=your_gateio_testnet_api_key
GATEIO_TESTNET_SECRET_KEY=your_gateio_testnet_secret_key


# ============ AI API KEYS ============
# Master toggle for AI features (analysis, news checking, sentiment)
# Set to "off" or "false" to completely disable AI and skip all API connections
# When disabled, bot relies purely on technical strategies without AI analysis
#
# You can use EITHER of these two equivalent settings:
#   USE_AI=off       (simple shorthand — recommended)
#   AI__ENABLED=off  (Pydantic nested-model style)
# Both set the same flag; USE_AI takes precedence if both are present.
#
# Accepted values: on/off, true/false, yes/no, 1/0 (case-insensitive)
USE_AI=on
# AI__ENABLED=on   # alternative form — uncomment if preferred

# At least one is needed to enable AI confidence scoring (optional)
# Providers are tried in priority order (GateRouter first when configured):
#   GateRouter (DeepSeek V3) → Ollama → Gemini Flash Lite → Gemini Flash → Grok → OpenRouter → OpenAI → Anthropic
# When a provider's quota is exceeded, the bot automatically switches to the next one.

# --- GateRouter.ai (HIGHEST PRIORITY — Gate.io's AI router, DeepSeek V3 premium) ---
# OpenAI-compatible API. Sign up at: https://www.gaterouter.ai/
# Generate key at: https://www.gaterouter.ai/dashboard/settings/keys
# Payment via Gate Pay credits — no extra setup needed.
# Supports smart routing (model=auto) or explicit models (deepseek/deepseek-chat).
GATEROUTER_API_KEY=your_gaterouter_api_key
# GATEROUTER_MODEL=deepseek/deepseek-chat

# --- Existing / Paid providers ---
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
OLLAMA_BASE_URL=http://localhost:11434

# --- FREE providers (recommended — no credits required) ---

# Google Gemini (free tier: ~1500 requests/day for Flash, higher for Flash Lite)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# xAI Grok (free tier available)
# Get your key at: https://console.x.ai/
GROK_API_KEY=your_grok_api_key

# OpenRouter — aggregator with many free models (e.g. mistral-7b-instruct:free)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key

# --- Model overrides (optional — sensible defaults are set) ---
# GATEROUTER_MODEL=deepseek/deepseek-chat
# GEMINI_FLASH_MODEL=gemini-2.5-flash
# GEMINI_FLASH_LITE_MODEL=gemini-2.5-flash-lite
# GROK_MODEL=grok-3-mini
# OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# ============ DATA SOURCE API KEYS (all optional) ============
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_API_ID=your_telegram_api_id
TELEGRAM_API_HASH=your_telegram_api_hash
# Your personal Telegram user ID (or group/channel ID) to receive all bot alerts.
# The bot will send ALL trade alerts, PnL notifications, and system messages ONLY
# to this chat ID. To find your user ID: message @userinfobot on Telegram.
# For a group/channel: use the numeric ID (e.g. -1001234567890).
TELEGRAM_CHAT_ID=your_telegram_chat_id

REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

DISCORD_BOT_TOKEN=your_discord_bot_token

POLYMARKET_API_KEY=your_polymarket_api_key

GLASSNODE_API_KEY=your_glassnode_api_key

# Santiment – on-chain & social metrics
# Sign up at: https://app.santiment.net/account#api-keys
# Required by data/sources/santiment_monitor.py (PR #90)
SANTIMENT_API_KEY=your_santiment_api_key

NEWSAPI_KEY=your_newsapi_key
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key

# ============ CROSS-ASSET DATA APIs (for regime detection) ============
# Alpha Vantage - Free tier: 25 requests/day
# Get your key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key

# FRED (Federal Reserve Economic Data) - Free, no rate limit
# Get your key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key

# Yahoo Finance - No API key needed (uses yfinance package)
# Used for S&P 500, VIX, and other indices
YAHOO_FINANCE_API_KEY=

# ============ INFRASTRUCTURE ============
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=sqlite:///./data/trading_bot.db

# ============ ALERTING (all optional) ============
ALERT_TELEGRAM_BOT_TOKEN=your_alert_bot_token
ALERT_TELEGRAM_CHAT_ID=your_chat_id
ALERT_DISCORD_WEBHOOK=your_discord_webhook_url
ALERT_EMAIL_SMTP_HOST=smtp.gmail.com
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_USERNAME=your_email
ALERT_EMAIL_PASSWORD=your_app_password
ALERT_EMAIL_TO=your_email

# ============ SECURITY ============
# Generate with: python main.py generate-keys
ENCRYPTION_KEY=your_fernet_encryption_key
SECRET_KEY=your_jwt_secret_key

# ============ BOT SETTINGS ============
TRADING_MODE=paper
PRIMARY_EXCHANGE=gateio
TRADING_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT,XAU/USDT

# Enable Forex trading features (default: false)
# ENABLE_FOREX_TRADING=false

# Gold Futures Configuration (Gate.io)
# ✅ Gold trading supported via XAU/USDT → auto-maps to XAUT/USDT (Tether Gold perpetual)
#
# IMPORTANT: Gate.io does NOT have native XAU/USDT on their standard futures API.
# The XAU/USDT perpetual visible in the Gate.io app is on their TradFi (MT5) platform.
#
# For crypto futures mode (TRADING_MODE=paper/live/testnet):
#   XAU/USDT -> auto-maps to XAUT/USDT (Tether Gold perpetual) on Gate.io standard futures.
#   XAUT is backed 1:1 by physical gold. Max leverage: 20x.
#   Simply add XAU/USDT to TRADING_PAIRS and it will work with Gate.io standard futures.
#
# For traditional gold (XAUUSD), use TRADING_MODE=forex_live with MT5 credentials:
#   Configure Gate.io TradFi MT5 credentials (GATEIO_TRADFI_LOGIN etc.)
#   Enable with: ENABLE_FOREX_TRADING=true

# Testnet / Demo mode (recommended for testing with real API flow)
# TRADING_MODE=testnet
# EXCHANGE_USE_TESTNET=true
# USE_TESTNET=true
# GATEIO_TESTNET_API_KEY=your_testnet_key
# GATEIO_TESTNET_SECRET_KEY=your_testnet_secret

# Generic testnet credentials — used for any exchange when TRADING_MODE=testnet.
# These take precedence over exchange-specific testnet keys.
# EXCHANGE_TESTNET_API_KEY=your_testnet_api_key
# EXCHANGE_TESTNET_API_SECRET=your_testnet_api_secret
# EXCHANGE_TESTNET_PASSWORD=your_testnet_passphrase
# Strategy to run — used for BACKTESTING only.
# Live and paper trading always use the intelligent StrategySelector which
# automatically picks the best 5-8 strategies based on current market
# microstructure (ADX, ATR, RSI, BBW), historical performance, and regime.
# Available strategies for backtesting:
#   Original: momentum, scalping, technical_breakout, dca, grid,
#             news_momentum, sentiment_reversal, ai_adaptive, whale_follower,
#             funding_rate_arb, market_making, liquidation_hunter,
#             smart_money_flow
#   New (31): bollinger_squeeze, vwap_deviation, ichimoku_cloud,
#             fibonacci_retracement, order_flow_imbalance, volume_profile,
#             rsi_divergence, macd_crossover, ema_ribbon, supertrend,
#             keltner_channel, donchian_breakout, parabolic_sar,
#             stochastic_rsi, williams_r, adx_trend, pivot_point,
#             harmonic_pattern, elliott_wave, supply_demand_zone,
#             market_structure_break, fair_value_gap, order_block,
#             accumulation_distribution, on_chain_momentum,
#             correlation_divergence, volatility_breakout, time_based,
#             mtf_confluence, range_breakout, momentum_divergence
STRATEGY=momentum
DEFAULT_LEVERAGE=5
MAX_LEVERAGE=20
DAILY_PROFIT_TARGET_PCT=1.0
MAX_DAILY_LOSS_PCT=2.0
MAX_POSITION_SIZE_PCT=10.0
MAX_OPEN_POSITIONS=5
# Starting balance for paper trading (USDT)
PAPER_TRADING_BALANCE=10000
LOG_LEVEL=INFO

# ============ PROFIT MAXIMIZATION ============
# Enable dynamic leverage scaling based on performance (default: true)
ENABLE_DYNAMIC_LEVERAGE=true
# Scale leverage up after consecutive wins (default: true)
LEVERAGE_SCALE_ON_WINS=true
# Minimum leverage when scaling dynamically (default: 3)
MIN_DYNAMIC_LEVERAGE=3
# Maximum leverage when scaling dynamically (default: 15)
MAX_DYNAMIC_LEVERAGE=15
# Number of consecutive wins before increasing leverage (default: 3)
WINS_FOR_LEVERAGE_INCREASE=3
# Automatically reinvest profits into larger position sizes (default: true)
COMPOUND_PROFITS=true
# Compound factor: fraction of profit to reinvest (0.0-1.0, default: 0.5)
COMPOUND_FACTOR=0.5
# Minimum trade quality score to execute trade (0.0-1.0, default: 0.6)
TRADE_QUALITY_THRESHOLD=0.6

# ============ DASHBOARD ============
# Port the web dashboard listens on (must match docker-compose.yml ports)
DASHBOARD_PORT=8080
# HTTP Basic Auth for the dashboard (leave unset to disable authentication)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me-in-production

# ============ RL & OPTIMIZATION CONFIGURATION ============
# Path to RL model storage (for strategy optimizer)
RL_MODEL_PATH=/app/data/rl_models
# Path to Bayesian optimizer state (for parameter tuner)
PARAMETER_TUNER_STATE_PATH=/app/data/parameter_tuner_state
# Enable RL strategy optimization (default: true)
ENABLE_RL_OPTIMIZATION=true
# Enable dynamic parameter tuning (default: true)
ENABLE_PARAMETER_TUNING=true
# Update parameters every N trades (default: 20)
PARAMETER_TUNING_UPDATE_INTERVAL=20

# ============ EXECUTION ENGINE CONFIGURATION ============
# Execution algorithm: "market" (default), "twap", "vwap", "iceberg", "sniper", "implementation_shortfall"
EXECUTION_ALGORITHM=market
# Enable adaptive execution (default: false - use for large orders only)
ENABLE_ADAPTIVE_EXECUTION=false
# Latency alert threshold in milliseconds (default: 100)
LATENCY_ALERT_THRESHOLD_MS=100
# Enable execution quality monitoring (default: true)
ENABLE_EXECUTION_QUALITY_MONITORING=true

# ============ DOCKER-SPECIFIC ENVIRONMENT VARIABLES ============
# These are set automatically by docker-compose.yml.
# Only override if using a non-standard network configuration.
#
# ZeroMQ channels (Rust engine ↔ Python supervisor):
#   ZMQ_TELEMETRY_URL=tcp://127.0.0.1:5555   (Rust PUB → Python SUB)
#   ZMQ_CONFIG_URL=tcp://127.0.0.1:5556      (Python PUSH → Rust PULL)
#   ZMQ_HEARTBEAT_TIMEOUT=10                  (seconds before engine is considered dead)
#
# Redis (shared state cache):
#   REDIS_URL=redis://127.0.0.1:6379          (requires network_mode: host)
#
# Regime service cadence:
#   REGIME_INTERVAL_SECONDS=300               (how often the regime detector updates)
#
# NOTE: All containers use network_mode: host, so 127.0.0.1 resolves
# to the host loopback where all services bind their ports.
